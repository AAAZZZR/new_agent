{
  "telegram": {
    "botToken": "${TELEGRAM_BOT_TOKEN}"
  },
  "llm": {
    "defaultProvider": "gemini",
    "defaultModel": "gemini-2.5-flash",
    "providers": {
      "gemini": {
        "apiKey": "${GEMINI_API_KEY}",
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai",
        "models": [
          "gemini-2.5-flash",
          "gemini-2.0-flash",
          "gemini-2.5-pro"
        ]
      },
      "anthropic": {
        "apiKey": "${ANTHROPIC_API_KEY}",
        "models": [
          "claude-opus-4-20250514",
          "claude-sonnet-4-20250514",
          "claude-haiku-4-20250414"
        ]
      }
    },
    "maxRetries": 2,
    "fallbackProvider": ""
  },
  "mcp": {
    "servers": [
      {
        "name": "test-tools",
        "transport": "stdio",
        "command": "node",
        "args": [
          "/home/ubuntu/new_agent/mcp-test-server/index.js"
        ]
      },
      {
        "name": "filesystem",
        "transport": "stdio",
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-filesystem",
          "/home/ubuntu/new_agent/workspace"
        ]
      }
    ]
  },
  "memory": {
    "enabled": false,
    "workspacePath": "./workspace"
  },
  "sandbox": {
    "enabled": false,
    "type": "subprocess",
    "timeoutMs": 30000,
    "memoryLimitMb": 256
  },
  "auth": {
    "ownerId": 8274521225,
    "guestPermissions": {
      "canUseTools": true,
      "canUseSandbox": false,
      "canReadMemory": false,
      "canWriteMemory": false
    }
  },
  "agent": {
    "name": "TestBot",
    "systemPrompt": "你是 TestBot，一個在 Telegram 群組裡的 AI 助手。你可以自由地和群組成員聊天、回答問題、使用工具。請用中文回覆，保持簡潔友善。",
    "persona": ""
  }
}